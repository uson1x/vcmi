{
	// Action buttons for the Adventure Options dialog.
	// Each entry defines:
	//   "legacyAnimation" - DEF animation, always used in classic mode and as fallback in enhanced mode.
	//   "overlay"         - (optional) Overlay image for enhanced mode. If present, the button animation
	//                       is generated from this image (placed under SPRITES/<overlay>).
	//                       If absent, legacyAnimation is used even in enhanced mode.
	//   "label"           - (optional) Translation key for the text label shown in enhanced mode.
	//   "shortcut"        - Shortcut identifier string (see ShortcutHandler). Used to look up
	//                       the callback and enabled-state from AdventureMapShortcuts::getShortcuts().
	"buttons" : [
		{ "legacyAnimation" : "ADVVIEW.DEF",   "label" : "vcmi.adventureOptions.viewWorld",    "shortcut" : "adventureViewWorld"    },
		{ "legacyAnimation" : "ADVPUZ.DEF",    "label" : "vcmi.adventureOptions.puzzle",       "shortcut" : "adventureViewPuzzle"   },
		{ "legacyAnimation" : "ADVDIG.DEF",    "label" : "vcmi.adventureOptions.dig",          "shortcut" : "adventureDigGrail"     },
		{ "legacyAnimation" : "ADVINFO.DEF",   "label" : "vcmi.adventureOptions.scenarioInfo", "shortcut" : "adventureViewScenario" },
		{ "legacyAnimation" : "ADVTURN.DEF",   "label" : "vcmi.adventureOptions.replayTurn",   "shortcut" : "adventureReplayTurn"   },
		{ "overlay" : "adventureOptionLobby",  "label" : "vcmi.lobby.login.title",             "shortcut" : "mainMenuLobby"         },
		{ "overlay" : "adventureOptionSearch", "label" : "vcmi.adventureMap.search.hover",     "shortcut" : "adventureSearch"       }
	]
}
